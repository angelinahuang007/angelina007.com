# Sanity CMS Configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_sanity_api_token_here

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://angelina007.com

# Analytics (Optional)
# Supports: Umami, Plausible, or Google Analytics
# For Umami: Use your website ID from Umami dashboard
# For Plausible: Use your site domain
# For Google Analytics: Use your measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_ANALYTICS_ID=

# Email Configuration (Optional - for contact form)
# NEXT_PUBLIC_CONTACT_EMAIL=your-email@example.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@angelina007.com

# Database Configuration (Optional - if using Umami with database)
# UMAMI_DB_PASSWORD=secure_password_here
# UMAMI_HASH_SALT=random_salt_here

# Digital Ocean Deployment (Optional - for CI/CD)
# These are used in GitHub Actions for deployment
# DROPLET_HOST=your-droplet-ip.com
# DROPLET_USER=deploy-user
# DROPLET_SSH_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# Development Settings
NODE_ENV=development
NEXT_PUBLIC_DEBUG=false

# API Configuration (Optional)
# NEXT_PUBLIC_API_URL=https://api.angelina007.com
# API_SECRET_KEY=your_api_secret_key
